                            <span class="text-xs text-gray-500 ml-5 mt-1">${stats.lowPrescExplanation}</span>
                            <span class="text-[10px] text-red-600 font-bold ml-5 mt-0.5 bg-white border border-red-200 px-1 py-0.5 rounded shadow-sm inline-block w-max">Accionar antes del: ${stats.actionDateStr}</span>
                        </li>
                    `);
                    criticalAndRiskProducts.push(prod);
                    if(sampleLowPresc.length < 2) sampleLowPresc.push(`<strong>${prod}</strong> (Tope: ${stats.actionDateStr})`);
                }

                if (stats.isDesbalance) {
                    transferCount++;
                    transfersList.push(`
                        <li class="flex flex-col mb-2 pb-2 border-b border-blue-100 last:border-0 hover:bg-blue-50 p-1 rounded transition-colors">
                            <div class="flex items-start">
                                <i class="fa-solid fa-truck-transfer text-blue-500 mt-1 mr-2 text-xs"></i>
                                <span class="text-gray-800 font-bold leading-tight">${prod}</span>
                            </div>
                            <span class="text-xs text-blue-700 ml-5 mt-1 font-medium bg-white px-1 py-0.5 rounded shadow-sm border border-blue-100 w-max inline-block">Sugerido: ${stats.transferDirection} (${stats.amountToTransfer} uds)</span>
                        </li>
                    `);
                    if(sampleTransfers.length < 1) sampleTransfers.push(`mover <strong>${stats.amountToTransfer} uds</strong> de ${prod}`);
                }
            }

            document.getElementById('kpi-transfer').innerText = transferCount > 0 ? `${transferCount} Productos` : 'Equilibrado';
            document.getElementById('kpi-transfer-sub').innerText = transferCount > 0 ? 'Acciones logísticas pendientes' : 'Sin desbalances';

            document.getElementById('list-overstock').innerHTML = overstockList.length > 0 
                ? overstockList.join('') : '<li class="text-gray-400 text-center mt-4">Estado óptimo: Sin problemas detectados.</li>';
                
            document.getElementById('list-low-presc').innerHTML = lowPrescList.length > 0 
                ? lowPrescList.join('') : '<li class="text-gray-400 text-center mt-4">Todos los productos tienen alta rotación.</li>';

            document.getElementById('list-transfers').innerHTML = transfersList.length > 0 
                ? transfersList.join('') : '<li class="text-gray-400 text-center mt-4">Inventario equilibrado entre tiendas.</li>';

            // --- Generación Inteligente de Acciones Recomendadas ---
            let actionHtml = '';
            let recommendations = [];

            if (transferCount > 0) {
                 recommendations.push(`
                    <div class="mb-3 p-4 bg-blue-50 rounded-lg border border-blue-200 hover:shadow-md transition-shadow cursor-pointer" onclick="openModal('transfers')">
                        <h4 class="font-bold text-blue-700 text-sm mb-1"><i class="fa-solid fa-circle text-blue-500 mr-1"></i> Estado Transferir: Compensación Logística</h4>
                        <p class="text-xs text-gray-700">Se han detectado <strong>${transferCount} productos</strong> con desbalance total. Se recomienda transferir estratégicamente el 50% del stock desde la tienda matriz hacia la sucursal vacía (Ej. ${sampleTransfers.join(', ')}).</p>
                    </div>
                `);
            }

            if (criticalAndRiskProducts.length > 0) {
                const isCritico = overstockList.length > 0 ? 'Crítico/Riesgo' : 'Riesgo';
                const semaforoColor = overstockList.length > 0 ? 'text-red-500' : 'text-orange-500';
                
                recommendations.push(`
                    <div class="mb-3 p-4 bg-red-50 rounded-lg border border-red-100 hover:shadow-md transition-shadow cursor-pointer" onclick="openModal('expiring')">
                        <h4 class="font-bold text-red-700 text-sm mb-1"><i class="fa-solid fa-circle ${semaforoColor} mr-1"></i> Estado ${isCritico}: Ofertas de Emergencia</h4>
                        <p class="text-xs text-gray-700">Para prevenir mermas por baja prescripción, aplicar descuentos a productos próximos a expirar iniciando promociones 3 meses antes del vencimiento. (Ej. para ${sampleLowPresc.join(', ')}).</p>
                    </div>
                `);
                recommendations.push(`
                    <div class="mb-3 p-4 bg-orange-50 rounded-lg border border-orange-100 hover:shadow-md transition-shadow cursor-pointer" onclick="switchTab('data')">
                        <h4 class="font-bold text-orange-700 text-sm mb-1"><i class="fa-solid fa-circle text-orange-500 mr-1"></i> Estado Riesgo: Cambio a Zonas Concurridas</h4>
                        <p class="text-xs text-gray-700">Reubicar productos con riesgo de estancamiento hacia mostradores principales, pasillos centrales o zonas calientes cercanas a las cajas registradoras para forzar compras por impulso.</p>
                    </div>
                `);
            }
            
            if (overstockList.length > 0) {
                recommendations.push(`
                    <div class="mb-3 p-4 bg-yellow-50 rounded-lg border border-yellow-200 hover:shadow-md transition-shadow cursor-pointer" onclick="switchTab('data')">
                        <h4 class="font-bold text-yellow-700 text-sm mb-1"><i class="fa-solid fa-circle text-yellow-500 mr-1"></i> Estado Atención: Auditoría Física FEFO</h4>
                        <p class="text-xs text-gray-700">Emitir instrucción al almacén para que los productos detectados con múltiples lotes (Sobrecompra) sean distribuidos estrictamente bajo sistema FEFO (Primero en expirar, primero en salir).</p>
                    </div>
                `);
            }

            if (recommendations.length === 0) {
                actionHtml = '<div class="text-gray-500 text-center mt-4 text-sm font-medium w-full col-span-2">Inventario totalmente sano. No se requieren acciones correctivas.</div>';
            } else {
                actionHtml = recommendations.join('');
            }
            document.getElementById('action-plan-container').innerHTML = actionHtml;
        }

        // --- AI INTEGRATION OPTIMIZADA ---
        function clearChat() {
            const chatHistory = document.getElementById('chatHistory');
            while (chatHistory.children.length > 1) {
                chatHistory.removeChild(chatHistory.lastChild);
            }
        }

        function appendMessage(role, text) {
            const chatHistory = document.getElementById('chatHistory');
            const msgDiv = document.createElement('div');
            msgDiv.className = role === 'user' ? 'flex items-start gap-4 flex-row-reverse' : 'flex items-start gap-4';
            
            const iconHtml = role === 'user' 
                ? `<div class="w-8 h-8 rounded-full bg-nexus-primary flex items-center justify-center shadow-sm shrink-0"><i class="fa-solid fa-user text-xs text-white"></i></div>`
                : `<div class="w-8 h-8 rounded-full bg-white flex items-center justify-center border border-blue-200 shrink-0 shadow-sm p-0.5"><img src="image_b906d0.png" alt="NEXUS AI" class="w-full h-full object-contain" onerror="this.src='https://placehold.co/100x100/0032a0/white?text=NX'"></div>`;
            
            const bubbleClass = role === 'user'
                ? `bg-nexus-primary text-white border border-nexus-primary rounded-2xl rounded-tr-none p-3 max-w-[85%] shadow-md`
                : `bg-white border border-gray-200 text-gray-800 rounded-2xl rounded-tl-none p-3 max-w-[85%] shadow-sm`;

            const contentHtml = role === 'user' ? text : marked.parse(text);
            msgDiv.innerHTML = `${iconHtml}<div class="${bubbleClass}"><div class="text-[13px] markdown-body ${role==='user'?'font-medium text-white':''} leading-relaxed">${contentHtml}</div></div>`;
            chatHistory.appendChild(msgDiv);
            chatHistory.scrollTop = chatHistory.scrollHeight;
        }

        function showTypingIndicator() {
            const chatHistory = document.getElementById('chatHistory');
            const msgDiv = document.createElement('div');
            msgDiv.id = 'typingIndicator';
            msgDiv.className = 'flex items-start gap-4';
            msgDiv.innerHTML = `
                <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center border border-blue-200 shrink-0 shadow-sm p-0.5">
                    <img src="image_b906d0.png" alt="NEXUS AI" class="w-full h-full object-contain" onerror="this.src='https://placehold.co/100x100/0032a0/white?text=NX'">
                </div>
                <div class="bg-white border border-gray-200 rounded-2xl rounded-tl-none p-4 max-w-[85%] shadow-sm flex items-center gap-1">
                    <div class="w-2 h-2 bg-nexus-primary rounded-full animate-bounce"></div>
                    <div class="w-2 h-2 bg-nexus-primary rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                    <div class="w-2 h-2 bg-nexus-primary rounded-full animate-bounce" style="animation-delay: 0.4s"></div>
                </div>
            `;
            chatHistory.appendChild(msgDiv);
            chatHistory.scrollTop = chatHistory.scrollHeight;
        }

        function removeTypingIndicator() {
            const indicator = document.getElementById('typingIndicator');
            if(indicator) indicator.remove();
        }

        async function fetchWithRetry(url, options, maxRetries = 5) {
            let delays = [1000, 2000, 4000, 8000, 16000];
            for (let i = 0; i < maxRetries; i++) {
                try {
                    const response = await fetch(url, options);
                    if (!response.ok) {
                        const errorDetails = await response.text();
                        console.error(`HTTP status ${response.status}:`, errorDetails);
                        throw new Error(`HTTP ${response.status} - ${errorDetails}`);
                    }
                    return await response.json();
                } catch (error) {
                    if (i === maxRetries - 1) throw error;
                    await new Promise(res => setTimeout(res, delays[i]));
                }
            }
        }

        async function handleSendChat(event) {
            event.preventDefault();
            const inputEl = document.getElementById('chatInput');
            const btnEl = document.getElementById('sendBtn');
            const query = inputEl.value.trim();
            
            if(!query) return;

            if(!appData.isLoaded) {
                alert("Por favor carga el documento de datos primero o usa los datos de muestra.");
                return;
            }

            appendMessage('user', query);
            inputEl.value = '';
            inputEl.disabled = true;
            btnEl.disabled = true;
            showTypingIndicator();

            try {
                const headersStr = appData.headers.join(' | ');
                const sampleRows = appData.rows.slice(0, 20).map(r => r.join(' | ')).join('\n');
                
                const problematicsDetected = Object.entries(appData.stats)
                    .filter(([_, stats]) => stats.isOverstock || stats.isLowPresc || stats.isDesbalance)
                    .map(([prod, stats]) => `- ${prod}: ${stats.statusText}`)
                    .slice(0, 100) 
                    .join('\n');
                
                const promptContext = `
A continuación se presenta un resumen ESTADÍSTICO procesado del inventario (archivo FIFO):
- Total de filas evaluadas: ${appData.rows.length}
- Columnas disponibles: ${headersStr}

Muestra cruda (primeras 20 filas para entender la estructura):
${sampleRows}

RESUMEN DE PROBLEMÁTICAS DETECTADAS (Sobrestock / Baja Prescripción / Desbalances de Transferencia):
${problematicsDetected || "Ninguna problemática detectada en este lote."}

Pregunta del usuario: "${query}"
`;

                const systemPrompt = "Eres NEXUS, un asistente virtual experto en análisis de datos e inventarios médicos. Tu tarea es responder a las preguntas del usuario basándote EXCLUSIVAMENTE en el contexto estadístico y crudo proporcionado. Responde en español de forma concisa, profesional y analítica. Utiliza formato markdown para resaltar información importante. La base de datos es muy grande, por lo que se te ha provisto un resumen procesado con los productos en estado de alerta o sobrestock. Ayuda al usuario a entender las soluciones o el estado general de estos productos basándote en la información dada.";

                const payload = {
                    contents: [{
                        role: "user",
                        parts: [{ text: promptContext }]
                    }],
                    systemInstruction: {
                        parts: [{ text: systemPrompt }]
                    }
                };

                const modelsToTry = [
                    "gemini-2.5-flash-preview-09-2025",
                    "gemini-2.5-flash",
                    "gemini-1.5-flash"
                ];

                let result = null;
                let lastError = null;

                for (const model of modelsToTry) {
                    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`;
                    try {
                        result = await fetchWithRetry(apiUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        }, 2);
                        
                        if (result) break; 
                    } catch (err) {
                        lastError = err;
                        console.warn(`Intento con el modelo ${model} falló:`, err.message);
                        if (!err.message.includes("404")) break; 
                    }
                }

                if (!result) {
                    throw lastError || new Error("No se pudo establecer conexión con ningún modelo de lenguaje disponible.");
                }

                removeTypingIndicator();

                if (result && result.candidates && result.candidates.length > 0) {
                    const candidate = result.candidates[0];
                    if (candidate.content && candidate.content.parts && candidate.content.parts.length > 0) {
                        const aiResponseText = candidate.content.parts[0].text;
                        appendMessage('ai', aiResponseText);
                    } else {
                        const reason = candidate.finishReason || "Desconocida";
                        appendMessage('ai', `⚠️ La IA procesó la solicitud pero no devolvió texto. Razón de finalización: ${reason}`);
                    }
                } else {
                    throw new Error("Estructura de respuesta inválida o vacía.");
                }

            } catch (error) {
                removeTypingIndicator();
                console.error("Gemini API Error:", error);
                
                let errorMessage = error.message;
                if (error.message.includes("429")) {
                    errorMessage = "Límite de cuota excedido (HTTP 429). Demasiadas peticiones o límite diario de la API alcanzado.";
                } else if (error.message.includes("HTTP")) {
                    errorMessage = `Error de red o API (${error.message.substring(0, 80)}...)`;
                }
                    
                appendMessage('ai', `Lo siento, ha ocurrido un error al conectar con la red neuronal de NEXUS.\n\n**Detalle del error:** \`${errorMessage}\`\n\nPor favor, inténtalo de nuevo en unos minutos.`);
            } finally {
                inputEl.disabled = false;
                btnEl.disabled = false;
                inputEl.focus();
            }
        }

        // --- SISTEMA DE REPORTE PDF POR CORREO ---
        async function sendPDFReport() {
            const emailInput = document.getElementById('reportEmail').value.trim();
            const feedback = document.getElementById('emailFeedback');
            
            if (!appData.isLoaded) {
                alert('Carga los datos del inventario primero para poder generar el reporte.');
                return;
            }
            
            if (!emailInput || !emailInput.includes('@') || !emailInput.includes('.')) {
                feedback.innerHTML = '<i class="fa-solid fa-triangle-exclamation text-red-500"></i> <span class="text-red-600">Por favor, ingresa un correo electrónico válido.</span>';
                feedback.classList.remove('hidden');
                return;
            }

            feedback.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin text-nexus-primary"></i> <span class="text-nexus-primary">Generando reporte inteligente y conectando con el servidor...</span>';
            feedback.classList.remove('hidden');

            try {
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF();
                
                // --- Diseño del PDF ---
                doc.setFontSize(18);
                doc.setTextColor(0, 50, 160); // NEXUS Primary
                doc.text('NEXUS - Control Inteligente de Inventario', 14, 20);
                
                doc.setFontSize(10);
                doc.setTextColor(100);
                doc.text(`Generado automáticamente para: ${emailInput}`, 14, 28);
                doc.text(`Fecha de emisión: ${new Date().toLocaleDateString('es-ES')}`, 14, 34);

                let startY = 45;

                // Tabla 1: Transferencias Logísticas
                const transfersData = [];
                Object.entries(appData.stats).filter(([_, s]) => s.isDesbalance).forEach(([prod, s]) => {
                    transfersData.push([prod, s.transferDirection, Math.round(s.amountToTransfer).toString()]);
                });

                if (transfersData.length > 0) {
                    doc.setFontSize(14);
                    doc.setTextColor(0, 86, 214); // Blue Secondary
                    doc.text('1. Transferencias entre Almacenes Recomendadas', 14, startY);
                    
                    doc.autoTable({
                        startY: startY + 5,
                        head: [['Producto', 'Ruta de Transferencia', 'Cant. Sugerida']],
                        body: transfersData,
                        theme: 'striped',
                        headStyles: { fillColor: [0, 86, 214] },
                        margin: { top: 10 }
                    });
                    startY = doc.lastAutoTable.finalY + 15;
                }

                // Tabla 2: Próximos a Vencer
                const expData = [];
                Object.entries(appData.stats)
                    .filter(([_, s]) => s.minVencim !== Infinity)
                    .sort((a,b) => a[1].minVencim - b[1].minVencim)
                    .slice(0, 40) // Top 40
                    .forEach(([prod, s]) => {
                        expData.push([prod, s.categoria, formatDateToStr(s.minVencim), Math.round(s.cantidadTotal).toString()]);
                    });

                if (expData.length > 0) {
                    if(startY > 230) { doc.addPage(); startY = 20; }
                    doc.setFontSize(14);
                    doc.setTextColor(234, 88, 12); // Orange
                    doc.text('2. Productos Próximos a Vencer (Top Riesgo)', 14, startY);
                    
                    doc.autoTable({
                        startY: startY + 5,
                        head: [['Producto', 'Categoría', 'Vencimiento', 'Stock (Uds)']],
                        body: expData,
                        theme: 'striped',
                        headStyles: { fillColor: [234, 88, 12] }
                    });
                    startY = doc.lastAutoTable.finalY + 15;
                }

                // Tabla 3: Baja Venta (Prescripción)
                const lowData = [];
                Object.entries(appData.stats).filter(([_, s]) => s.isLowPresc).forEach(([prod, s]) => {
                    lowData.push([prod, Math.round(s.salidasMensuales).toString(), Math.round(s.cantidadTotal).toString(), s.actionDateStr || 'Revisar']);
                });

                if (lowData.length > 0) {
                    if(startY > 230) { doc.addPage(); startY = 20; }
                    doc.setFontSize(14);
                    doc.setTextColor(220, 38, 38); // Red
                    doc.text('3. Alerta: Baja Prescripción / Venta', 14, startY);
                    
                    doc.autoTable({
                        startY: startY + 5,
                        head: [['Producto', 'Salidas/Mes', 'Stock Actual', 'Fecha Tope de Acción']],
                        body: lowData,
                        theme: 'striped',
                        headStyles: { fillColor: [220, 38, 38] }
                    });
                }

                if (transfersData.length === 0 && expData.length === 0 && lowData.length === 0) {
                    doc.setFontSize(12);
                    doc.setTextColor(34, 197, 94); // Green
                    doc.text('Inventario Óptimo. No se encontraron problemáticas que reportar.', 14, startY);
                }

                // --- LÓGICA DE ENVÍO DIRECTO ---
                
                // 1. Convertir el PDF a formato Blob (Archivo binario real)
                const pdfBlob = doc.output('blob');
                
                // 2. Preparar la carga útil que recibiría el servidor de correos
                const formData = new FormData();
                formData.append('to_email', emailInput);
                formData.append('subject', 'Reporte Inteligente NEXUS - Control de Inventario');
                formData.append('attachment', pdfBlob, `Reporte_NEXUS_${new Date().getTime()}.pdf`);

                /* * NOTA PARA EL DESARROLLADOR O ADMINISTRADOR DEL SISTEMA:
                 * Debido a las restricciones de seguridad web, los navegadores no pueden enviar correos "en secreto" 
                 * por sí mismos. Requieren de un servidor backend (API) para procesar y despachar el correo.
                 * * Para conectar esto de forma 100% real a tu empresa, simplemente debes habilitar un endpoint propio 
                 * en tu servidor o usar un servicio de terceros como SendGrid, Resend, Make o EmailJS y sustituir el 
                 * fetch de abajo por tu URL real.
                 *
                 * Ejemplo del código activo real:
                 * await fetch('https://api.tu-servidor-nexus.com/enviar-correo', { method: 'POST', body: formData });
                 */

                // Simulación de respuesta de éxito de red para propósitos de la interfaz de usuario.
                setTimeout(() => {
                    // Opcional: Como estamos en un entorno sin backend configurado, descargaremos el PDF como respaldo 
                    // para que el usuario no lo pierda, simulando al mismo tiempo la confirmación del envío.
                    doc.save(`NEXUS_Reporte_${new Date().getTime()}.pdf`);
                    
                    feedback.innerHTML = `<i class="fa-solid fa-check-circle text-green-500"></i> <span class="text-green-600 font-bold">¡Reporte procesado exitosamente para ${emailInput}! (Archivo adjunto descargado)</span>`;
                    
                    setTimeout(() => {
                        feedback.classList.add('hidden');
                        document.getElementById('reportEmail').value = '';
                    }, 6000);
                }, 1500);

            } catch (err) {
                console.error(err);
                feedback.innerHTML = '<i class="fa-solid fa-triangle-exclamation text-red-500"></i> <span class="text-red-600">Ocurrió un error al generar y enviar el reporte PDF.</span>';
            }
        }
    </script>
