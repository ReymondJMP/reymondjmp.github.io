        function filterTable() {
            const searchEl = document.getElementById('searchInput');
            const filterEl = document.getElementById('statusFilter');
            
            const input = searchEl ? searchEl.value.toLowerCase() : '';
            const statusFilter = filterEl ? filterEl.value : 'ALL';
            
            const tbody = document.getElementById('tableBody');
            if (!tbody) return;
            
            const trs = tbody.getElementsByTagName('tr');
            let visibleCount = 0;

            for (let i = 0; i < trs.length; i++) {
                const text = trs[i].innerText.toLowerCase();
                const statusCell = trs[i].getElementsByTagName('td')[0];
                const statusText = statusCell ? statusCell.getAttribute('title') : '';
                
                let matchesSearch = text.includes(input);
                let matchesStatus = (statusFilter === 'ALL') || (statusText && statusText.includes(statusFilter));

                if (matchesSearch && matchesStatus) {
                    trs[i].style.display = "";
                    visibleCount++;
                } else {
                    trs[i].style.display = "none";
                }
            }
            
            const countEl = document.getElementById('filteredCount');
            if (countEl) {
                countEl.innerText = `Mostrando ${visibleCount} de ${trs.length}`;
            }
        }

