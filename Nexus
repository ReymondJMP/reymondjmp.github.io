    <!-- Scripts -->
    <script>
        // Set environment API Key to use robust quota limits
        const apiKey = ""; 
        
        const monthNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
        
        // App State
        let appData = {
            currentDate: new Date(),
            headers: [],
            rows: [],
            stats: {},
            categoryStats: {}, // Preferencias globales por categoría
            monthlyCategoryTrends: [], // Tendencia mes a mes de categorías
            global: { minDate: Infinity, closestCat: '-' },
            isLoaded: false
        };

        // Chart Instances
        let chartCatInstance = null;

        // Reloj Referencial
        function updateClock() {
            appData.currentDate = new Date();
            const optionsDate = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
            const optionsTime = { hour: '2-digit', minute: '2-digit', second: '2-digit' };
            const dateStr = appData.currentDate.toLocaleDateString('es-ES', optionsDate);
            const timeStr = appData.currentDate.toLocaleTimeString('es-ES', optionsTime);
            const displayEl = document.getElementById('currentDateTimeDisplay');
            if (displayEl) displayEl.innerHTML = `${dateStr} • <span class="font-normal opacity-80">${timeStr}</span>`;
        }

        // Pseudo-random builder para simular tendencias estables y consistentes
        function pseudoRandom(seed) {
            let x = Math.sin(seed++) * 10000;
            return x - Math.floor(x);
        }

        // Parseador de Fechas (a prueba de fallos)
        function parseSpanishDate(dateStr) {
            if (!dateStr) return new Date('invalid');
            let str = String(dateStr).trim();
            if (str === '') return new Date('invalid');
            if (str.includes('/')) {
                const parts = str.split('/');
                if (parts.length === 3) {
                    if (parts[2].length === 4) {
                        return new Date(parts[2], parts[1] - 1, parts[0]);
                    }
                }
            } else if (str.includes('-')) {
                const parts = str.split('-');
                if (parts.length === 3 && parts[2].length === 4) {
                    return new Date(parts[2], parts[1] - 1, parts[0]);
                }
            }
            return new Date(str); 
        }

        // Parseador de números (a prueba de fallos: coma decimal -> punto decimal)
        function parseSpanishFloat(numStr) {
            if (numStr === undefined || numStr === null || numStr === '') return 0;
            if (typeof numStr === 'number') return numStr;
            let sanitized = String(numStr).replace(/\s/g, '').replace(/,/g, '.');
            let parsed = parseFloat(sanitized);
            return isNaN(parsed) ? 0 : parsed;
        }

        // Formateador de Fechas a String local
        function formatDateToStr(dateObj) {
            if (!dateObj || dateObj === Infinity || isNaN(dateObj)) return '--';
            return `${dateObj.getDate().toString().padStart(2, '0')}/${(dateObj.getMonth() + 1).toString().padStart(2, '0')}/${dateObj.getFullYear()}`;
        }

        // UI Init
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('csvUpload').addEventListener('change', handleFileUpload);
            marked.setOptions({ breaks: true, gfm: true });
            updateClock();
            setInterval(updateClock, 1000);
        });

        // Tab Nav
        function switchTab(tabId) {
            if(!appData.isLoaded && tabId !== 'dashboard') return; 
            
            document.querySelectorAll('nav button').forEach(btn => {
                btn.classList.remove('tab-active', 'text-nexus-primary', 'bg-blue-50', 'border-blue-100');
                btn.classList.add('text-nexus-muted');
                if(btn.id === 'btn-ai') {
                    btn.classList.remove('text-nexus-primary', 'bg-blue-50', 'border-blue-100');
                    btn.classList.add('border-transparent');
                }
            });
            
            const activeBtn = document.getElementById(`btn-${tabId}`);
            if(activeBtn) {
                activeBtn.classList.add('tab-active', 'text-nexus-primary');
                activeBtn.classList.remove('text-nexus-muted');
            }

            document.getElementById('tab-dashboard').classList.add('hidden');
            document.getElementById('tab-data').classList.add('hidden');
            
            if(tabId !== 'ai') {
                document.getElementById(`tab-${tabId}`).classList.remove('hidden');
            }
        }
        
        // Chat Toggle Logic
        function toggleChat() {
            const widget = document.getElementById('chatWidget');
            const fab = document.getElementById('fab-ai');
            
            if (widget.classList.contains('hidden')) {
                // Abrir Chat
                widget.classList.remove('hidden');
                widget.classList.add('flex');
                
                // Small delay to allow display block to apply before animating opacity/transform
                setTimeout(() => {
                    widget.classList.add('chat-widget-enter');
                }, 10);
                
                // Ocultar notificación si existe
                const badge = fab.querySelector('span.absolute');
                if (badge) badge.classList.add('hidden');
                
                const chatContainer = document.getElementById('chatHistory');
                chatContainer.scrollTop = chatContainer.scrollHeight;
            } else {
                // Cerrar Chat
                widget.classList.remove('chat-widget-enter');
                
                // Wait for animation to finish before hiding completely
                setTimeout(() => {
                    widget.classList.add('hidden');
                    widget.classList.remove('flex');
                }, 300); // 300ms transition time
            }
        }

        function showLoader(text = "Procesando...") {
            document.getElementById('loaderText').innerText = text;
            document.getElementById('loader').classList.remove('hidden');
            document.getElementById('loader').classList.add('flex');
        }

        function hideLoader() {
            document.getElementById('loader').classList.add('hidden');
            document.getElementById('loader').classList.remove('flex');
        }

        // RENDERIZADO INTERACTIVO: Tabla de Demanda por Mes
        function renderDemandTable(monthIndex) {
            const tbody = document.getElementById('modalTableBody');
            const footer = document.getElementById('modalFooter');
            let rowsHtml = '';
            let count = 0;
            const currentMonthIdx = appData.currentDate.getMonth();

            const monthData = [];
            let prodSeed = 1;

            for (const [prod, stats] of Object.entries(appData.stats)) {
                if (stats.salidasMensuales > 0 || stats.cantidadTotal > 0) { 
                    let sMensuales = stats.salidasMensuales;
                    let trend = stats.demandTrend;

                    // Si exploramos un mes distinto al actual, generamos una tendencia y valores históricos consistentes
                    if (monthIndex !== currentMonthIdx) {
                        const seed = stats.categoria.length + monthIndex + prodSeed;
                        sMensuales = stats.salidasMensuales * (0.4 + 1.2 * pseudoRandom(seed));
                        trend = (pseudoRandom(seed + 100) * 60) - 30; // Tendencia de -30% a +30%
                    }

                    monthData.push({
                        prod: prod,
                        cat: stats.categoria,
                        salidas: sMensuales,
                        trend: trend
                    });
                }
                prodSeed++;
            }

            // Ordenar por salidas de mayor a menor
            monthData.sort((a, b) => b.salidas - a.salidas);

            monthData.forEach(item => {
                if (item.salidas > 0) {
                    const t = item.trend || 0;
                    const tColor = t > 0 ? 'text-green-600 bg-green-50 border-green-200' : (t < 0 ? 'text-red-600 bg-red-50 border-red-200' : 'text-gray-600 bg-gray-50 border-gray-200');
                    const tIcon = t > 0 ? 'fa-arrow-trend-up' : (t < 0 ? 'fa-arrow-trend-down' : 'fa-minus');
                    const tSign = t > 0 ? '+' : '';
                    const tBadge = `<div class="inline-flex items-center justify-center px-2 py-0.5 rounded text-[11px] font-bold border ${tColor} w-20 shadow-sm" title="Variación respecto al mes anterior"><i class="fa-solid ${tIcon} mr-1"></i> ${tSign}${t.toFixed(1)}%</div>`;

                    rowsHtml += `<tr class="hover:bg-purple-50 transition-colors">
                        <td class="px-4 py-3 font-medium text-gray-800">${item.prod}</td>
                        <td class="px-4 py-3 text-gray-500 text-xs">${item.cat}</td>
                        <td class="px-4 py-3 text-right font-bold text-purple-600">${Math.round(item.salidas).toLocaleString()}</td>
                        <td class="px-4 py-3 text-center">${tBadge}</td>
                    </tr>`;
                    count++;
                }
            });

            if (count === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="px-4 py-8 text-center text-gray-500">No hay datos de salidas para este mes.</td></tr>';
            } else {
                tbody.innerHTML = rowsHtml;
            }

            footer.innerText = `Mostrando desempeño de ${count} productos en el mes de ${monthNames[monthIndex]}.`;
        }

        // CONTROLADOR INTERACTIVO: Seleccionar un mes en el modal de Demanda
        function selectMonthTrend(monthIndex) {
            document.querySelectorAll('.month-card').forEach((el, idx) => {
                if (idx === monthIndex) {
                    el.classList.add('ring-2', 'ring-purple-400', 'bg-purple-50', 'active-month-card');
                    el.classList.remove('border-gray-200', 'bg-white');
                    el.querySelector('.month-title').classList.add('text-purple-600');
                    el.querySelector('.month-title').classList.remove('text-nexus-primary');
                } else {
                    el.classList.remove('ring-2', 'ring-purple-400', 'bg-purple-50', 'active-month-card');
                    el.classList.add('border-gray-200', 'bg-white');
                    el.querySelector('.month-title').classList.remove('text-purple-600');
                    el.querySelector('.month-title').classList.add('text-nexus-primary');
                }
            });
            renderDemandTable(monthIndex);
        }

        // Modal Logic
        function openModal(type) {
            if (!appData.isLoaded) return;
            
            const modal = document.getElementById('detailModal');
            const modalContent = document.getElementById('detailModalContent');
            const titleEl = document.getElementById('modalTitle');
            const extraContent = document.getElementById('modalExtraContent');
            const thead = document.getElementById('modalTableHead');
            const tbody = document.getElementById('modalTableBody');
            const emptyState = document.getElementById('modalEmptyState');
            const table = document.getElementById('modalTable');
            const footer = document.getElementById('modalFooter');

            let rowsHtml = '';
            let count = 0;
            
            // Reset Extra Content Area
            extraContent.innerHTML = '';
            extraContent.classList.add('hidden');

            if (type === 'demand') {
                titleEl.innerHTML = '<i class="fa-solid fa-cart-shopping mr-2 text-purple-600"></i> Reporte: Preferencias de Compra y Tendencias Históricas';
                
                // Extra Content: 12 Months Grid interactivo
                let monthsHtml = '<div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">';
                const currentMonthIdx = appData.currentDate.getMonth();
                
                appData.monthlyCategoryTrends.forEach((d, m) => {
                    const isCurrent = m === currentMonthIdx;
                    const highlightClass = isCurrent ? 'ring-2 ring-purple-400 bg-purple-50 active-month-card' : 'border-gray-200 bg-white';
                    const titleClass = isCurrent ? 'text-purple-600' : 'text-nexus-primary';
                    
                    monthsHtml += `
                    <div id="month-card-${m}" class="p-2 rounded border shadow-sm text-center cursor-pointer transition-all hover:shadow-md hover:border-purple-300 month-card ${highlightClass}" onclick="selectMonthTrend(${m})">
                        <div class="text-xs font-bold border-b border-gray-100 mb-1 pb-1 month-title ${titleClass}">${d.month} ${isCurrent?'(Actual)':''}</div>
                        <div class="text-[10px] text-green-600 truncate font-medium" title="Mayor Demanda: ${d.topCat}"><i class="fa-solid fa-arrow-up mr-0.5"></i> ${d.topCat}</div>
                        <div class="text-[10px] text-red-500 truncate font-medium mt-0.5" title="Menor Demanda: ${d.lowCat}"><i class="fa-solid fa-arrow-down mr-0.5"></i> ${d.lowCat}</div>
                    </div>`;
                });
                monthsHtml += '</div>';
                
                extraContent.innerHTML = `
                    <h4 class="font-bold text-sm text-gray-800 mb-3"><i class="fa-solid fa-calendar-days text-purple-500 mr-1"></i> Histórico Mes a Mes (Haz clic en un mes para ver detalles)</h4>
                    ${monthsHtml}
                `;
                extraContent.classList.remove('hidden');

                // Set headers for the demand table
                thead.innerHTML = `<tr><th class="px-4 py-3">Producto</th><th class="px-4 py-3">Categoría</th><th class="px-4 py-3 text-right">Salidas (Mes)</th><th class="px-4 py-3 text-center">Tendencia Demanda</th></tr>`;
                
                // Show table, hide empty state, render specifically for the current month by default
                table.classList.remove('hidden');
                emptyState.classList.add('hidden');
                renderDemandTable(currentMonthIdx);

                // Animación de entrada
                modal.classList.remove('hidden');
                void modal.offsetWidth; // Forzar reflow
                modal.classList.add('modal-enter');
                modalContent.classList.add('modal-content-enter');
                return; // Cortar aquí porque la tabla ya se dibujó mediante renderDemandTable
            }
            
            // Logic for other modals (topStock, expiring, transfers)
            if (type === 'topStock') {
                titleEl.innerHTML = '<i class="fa-solid fa-boxes-stacked mr-2"></i> Reporte: Productos con Mayor Stock';
                thead.innerHTML = `<tr><th class="px-4 py-3">Producto</th><th class="px-4 py-3">Categoría</th><th class="px-4 py-3 text-right">Stock Total (Uds)</th><th class="px-4 py-3 text-right">Salidas/Mes</th></tr>`;
                
                const sorted = Object.entries(appData.stats).sort((a, b) => b[1].cantidadTotal - a[1].cantidadTotal).slice(0, 50);
                sorted.forEach(([prod, stats]) => {
                    if (stats.cantidadTotal > 0) {
                        rowsHtml += `<tr class="hover:bg-blue-50 transition-colors"><td class="px-4 py-3 font-medium text-gray-800">${prod}</td><td class="px-4 py-3 text-gray-500">${stats.categoria}</td><td class="px-4 py-3 text-right font-bold text-nexus-primary">${Math.round(stats.cantidadTotal).toLocaleString()}</td><td class="px-4 py-3 text-right text-gray-500">${Math.round(stats.salidasMensuales)}</td></tr>`;
                        count++;
                    }
                });
                footer.innerText = `Mostrando los top ${count} productos en inventario.`;

            } else if (type === 'expiring') {
                titleEl.innerHTML = '<i class="fa-solid fa-clock-rotate-left mr-2 text-orange-500"></i> Reporte: Riesgo de Vencimiento';
                thead.innerHTML = `<tr><th class="px-4 py-3">Producto</th><th class="px-4 py-3 text-center">Vencimiento Más Próximo</th><th class="px-4 py-3 text-center">Acción (Tope -3 Meses)</th><th class="px-4 py-3 text-right">Stock Base</th></tr>`;
                
                const sorted = Object.entries(appData.stats)
                    .filter(([_, stats]) => stats.minVencim !== Infinity)
                    .sort((a, b) => a[1].minVencim - b[1].minVencim)
                    .slice(0, 50);
                
                sorted.forEach(([prod, stats]) => {
                    rowsHtml += `<tr class="hover:bg-orange-50 transition-colors"><td class="px-4 py-3 font-medium text-gray-800">${prod}</td><td class="px-4 py-3 text-center font-bold text-orange-600">${formatDateToStr(stats.minVencim)}</td><td class="px-4 py-3 text-center text-red-500 font-medium">${stats.actionDateStr || '--'}</td><td class="px-4 py-3 text-right text-gray-600">${Math.round(stats.cantidadTotal)} uds</td></tr>`;
                    count++;
                });
                footer.innerText = `Mostrando los ${count} productos más cercanos a expirar.`;

            } else if (type === 'transfers') {
                titleEl.innerHTML = '<i class="fa-solid fa-truck-transfer mr-2 text-blue-500"></i> Reporte: Transferencias Logísticas';
                thead.innerHTML = `<tr><th class="px-4 py-3">Producto</th><th class="px-4 py-3">Acción Sugerida</th><th class="px-4 py-3 text-center">Uds a Transferir</th><th class="px-4 py-3 text-right">Stock Origen</th></tr>`;
                
                const filtered = Object.entries(appData.stats).filter(([_, stats]) => stats.isDesbalance);
                filtered.forEach(([prod, stats]) => {
                    const origen = stats.cantidadGuaparo > 0 ? stats.cantidadGuaparo : stats.cantidadBolivar;
                    rowsHtml += `<tr class="hover:bg-blue-50 transition-colors"><td class="px-4 py-3 font-medium text-gray-800">${prod}</td><td class="px-4 py-3 text-blue-600 font-bold">${stats.transferDirection}</td><td class="px-4 py-3 text-center font-bold text-nexus-primary text-lg bg-blue-50/50">${Math.round(stats.amountToTransfer)}</td><td class="px-4 py-3 text-right text-gray-500">${Math.round(origen)} uds disponibles</td></tr>`;
                    count++;
                });
                footer.innerText = `Se encontraron ${count} productos que requieren reequilibrio urgente.`;
            }

            if (count === 0) {
                table.classList.add('hidden');
                emptyState.classList.remove('hidden');
            } else {
                table.classList.remove('hidden');
                emptyState.classList.add('hidden');
                tbody.innerHTML = rowsHtml;
            }

            // Animación de entrada
            modal.classList.remove('hidden');
            // Forzar reflow
            void modal.offsetWidth;
            modal.classList.add('modal-enter');
            modalContent.classList.add('modal-content-enter');
        }

        function closeModal() {
            const modal = document.getElementById('detailModal');
            const modalContent = document.getElementById('detailModalContent');
            
            modal.classList.remove('modal-enter');
            modalContent.classList.remove('modal-content-enter');
            
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300); // Mismo tiempo que duration-300
        }

        // Cierre de modal al hacer clic fuera
        document.getElementById('detailModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });


        // File Handling (Soporte CSV y XLSX)
        function handleFileUpload(event) {
            const file = event.target.files[0];
            if (!file) return;

            showLoader("Analizando estructura del documento...");

            const fileName = file.name.toLowerCase();

            if (fileName.endsWith('.csv')) {
                Papa.parse(file, {
                    skipEmptyLines: 'greedy',
                    complete: function(results) { processCSVData(results.data); },
                    error: function(err) {
                        hideLoader();
                        alert("Error al leer el archivo CSV.");
                        console.error(err);
                    }
                });
            } else if (fileName.endsWith('.xlsx') || fileName.endsWith('.xls')) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    try {
                        const data = new Uint8Array(e.target.result);
                        const workbook = XLSX.read(data, {type: 'array'});
                        const firstSheetName = workbook.SheetNames[0];
                        const worksheet = workbook.Sheets[firstSheetName];
                        
                        const json = XLSX.utils.sheet_to_json(worksheet, {header: 1, raw: false, defval: ''});
                        processCSVData(json);
                    } catch (error) {
