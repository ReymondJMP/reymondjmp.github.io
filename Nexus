        function analyzeStock() {
            const almIndex = appData.headers.findIndex(h => h.toUpperCase() === 'ALM' || h.toUpperCase().includes('ALMACEN') || h.toUpperCase().includes('ALMACÉN'));
            const catIndex = appData.headers.findIndex(h => h.toUpperCase().includes('CATEG'));
            const descIndex = appData.headers.findIndex(h => h.toUpperCase().includes('DESCRIPCION') || h.toUpperCase().includes('PRODUCTO'));
            const loteIndex = appData.headers.findIndex(h => h.toUpperCase().includes('LOTE'));
            const vencimIndex = appData.headers.findIndex(h => h.toUpperCase().includes('VENCIM'));
            const salidasIndex = appData.headers.findIndex(h => h.toUpperCase().includes('SALIDA'));
            const cantidadIndex = appData.headers.findIndex(h => h.toUpperCase().includes('CANTIDAD') || h.toUpperCase() === 'SALDO');
            const fallbackCantidadIndex = cantidadIndex !== -1 ? cantidadIndex : appData.headers.findIndex(h => h.toUpperCase() === 'PIEZAS' || h.toUpperCase() === 'PRODUCTO');

            appData.stats = {};
            appData.categoryStats = {};
            appData.monthlyCategoryTrends = [];
            appData.global = { minDate: Infinity, closestCat: '-' };
            const now = appData.currentDate;

            appData.rows.forEach((row, rowIndex) => {
                const desc = (descIndex !== -1 && row[descIndex]) ? String(row[descIndex]).trim() : 'Producto ' + rowIndex;
                const lote = (loteIndex !== -1 && row[loteIndex]) ? String(row[loteIndex]).trim() : '';
                
                let cat = (catIndex !== -1 && row[catIndex]) ? String(row[catIndex]).trim() : 'Sin Categoría';
                if (!cat || cat === '') cat = 'Sin Categoría';

                let salidas = salidasIndex !== -1 ? parseSpanishFloat(row[salidasIndex]) : 0;
                let cantidad = fallbackCantidadIndex !== -1 ? parseSpanishFloat(row[fallbackCantidadIndex]) : 0;
                
                let almValue = (almIndex !== -1 && row[almIndex]) ? String(row[almIndex]).toUpperCase() : '';
                let isGuaparo = almValue.includes('721') || almValue.includes('GUAPARO');
                let isBolivar = almValue.includes('703') || almValue.includes('BOLIVAR') || almValue.includes('BOLÍVAR');

                if(!appData.stats[desc]) {
                    appData.stats[desc] = { categoria: cat, count: 0, lotes: new Set(), salidasMensuales: 0, cantidadTotal: 0, cantidadGuaparo: 0, cantidadBolivar: 0, minVencim: Infinity, actionDateStr: '', demandTrend: 0 };
                }
                appData.stats[desc].count += 1; 
                appData.stats[desc].salidasMensuales += salidas;
                appData.stats[desc].cantidadTotal += cantidad;
                
                if (isGuaparo) appData.stats[desc].cantidadGuaparo += cantidad;
                if (isBolivar) appData.stats[desc].cantidadBolivar += cantidad;
                
                if(lote && lote !== '') appData.stats[desc].lotes.add(lote);
                else appData.stats[desc].lotes.add('GenLote-' + rowIndex);

                if(!appData.categoryStats[cat]) {
                    appData.categoryStats[cat] = { salidasTotales: 0, stockTotal: 0 };
                }
                appData.categoryStats[cat].salidasTotales += salidas;
                appData.categoryStats[cat].stockTotal += cantidad;

                if (vencimIndex !== -1 && catIndex !== -1) {
                    const dateStr = row[vencimIndex];
                    if (dateStr && String(dateStr).trim() !== '') {
                        const dateObj = parseSpanishDate(dateStr);
                        if (!isNaN(dateObj) && dateObj > now) {
                            if (dateObj < appData.global.minDate) {
                                appData.global.minDate = dateObj;
                                appData.global.closestCat = cat;
                            }
                            if (dateObj < appData.stats[desc].minVencim) {
                                appData.stats[desc].minVencim = dateObj;
                            }
                        }
                    }
                }
            });

            // Generar Histórico Mensual Simulado y Tendencias
            for (let m = 0; m < 12; m++) {
                let maxCat = 'N/A', minCat = 'N/A', maxVal = -1, minVal = Infinity;
                for (const cat in appData.categoryStats) {
                    const base = appData.categoryStats[cat].salidasTotales;
                    if(base === 0) continue;
                    // Formula determinística para simular variaciones lógicas de mes a mes
                    const seed = cat.length + m;
                    const simulatedVal = base * (0.6 + 0.8 * pseudoRandom(seed)); 
                    
                    if(simulatedVal > maxVal) { maxVal = simulatedVal; maxCat = cat; }
                    if(simulatedVal < minVal) { minVal = simulatedVal; minCat = cat; }
                }
                appData.monthlyCategoryTrends.push({
                    month: monthNames[m],
                    topCat: maxCat, topVal: maxVal,
                    lowCat: minCat, lowVal: minVal
                });
            }

            let prodSeed = 1;
            for (const desc in appData.stats) {
                const stats = appData.stats[desc];
                
                // Generar tendencia de semaforización (de -30% a +30%)
                stats.demandTrend = (pseudoRandom(prodSeed) * 60) - 30;
                prodSeed++;

                let isOverstock = stats.lotes.size > 3;
                let isLowPresc = false;
                let lowPrescExplanation = "";
                let isDesbalance = false;
                let transferDirection = "";
                let amountToTransfer = 0;

                if ((salidasIndex !== -1 || fallbackCantidadIndex !== -1) && stats.minVencim !== Infinity) {
                    const msFaltantes = stats.minVencim - now;
                    if (msFaltantes > 0) {
                        const mesesFaltantes = msFaltantes / (1000 * 60 * 60 * 24 * 30.44);
                        const salidasProyectadas = stats.salidasMensuales * mesesFaltantes;
                        if (stats.cantidadTotal > salidasProyectadas) {
                            isLowPresc = true;
                            lowPrescExplanation = `Stock (${Math.round(stats.cantidadTotal)}) > Proyección de Salidas (${Math.round(salidasProyectadas)})`;
                            
                            let actionDate = new Date(stats.minVencim);
                            actionDate.setMonth(actionDate.getMonth() - 3);
                            stats.actionDateStr = `${actionDate.getDate().toString().padStart(2,'0')}/${(actionDate.getMonth() + 1).toString().padStart(2,'0')}/${actionDate.getFullYear()}`;
                        }
                    }
                } else if (salidasIndex === -1 && fallbackCantidadIndex === -1 && stats.count === 1) {
                    isLowPresc = true;
                    lowPrescExplanation = `1 sola entrada registrada.`;
                }

                if (stats.cantidadGuaparo > 0 && stats.cantidadBolivar <= 0) {
                    isDesbalance = true;
                    amountToTransfer = Math.floor(stats.cantidadGuaparo / 2) || 1;
                    transferDirection = `Guaparo ➔ Av. Bolívar`;
                } else if (stats.cantidadBolivar > 0 && stats.cantidadGuaparo <= 0) {
                    isDesbalance = true;
                    amountToTransfer = Math.floor(stats.cantidadBolivar / 2) || 1;
                    transferDirection = `Av. Bolívar ➔ Guaparo`;
                }

                stats.isOverstock = isOverstock;
                stats.isLowPresc = isLowPresc;
                stats.lowPrescExplanation = lowPrescExplanation;
                stats.isDesbalance = isDesbalance;
                stats.transferDirection = transferDirection;
                stats.amountToTransfer = amountToTransfer;

                if (isOverstock && isLowPresc) {
                    stats.statusIcon = '<i class="fa-solid fa-circle text-red-500"></i>';
                    stats.statusText = 'Crítico: Sobrecompra y Baja Prescripción';
                    stats.statusColorClass = 'bg-red-50 text-red-700 border-red-200';
                    stats.semaforoVal = 'Crítico';
                } else if (isLowPresc) {
                    stats.statusIcon = '<i class="fa-solid fa-circle text-orange-500"></i>';
                    stats.statusText = 'Riesgo: Baja Prescripción';
                    stats.statusColorClass = 'bg-orange-50 text-orange-700 border-orange-200';
                    stats.semaforoVal = 'Riesgo';
                } else if (isOverstock) {
                    stats.statusIcon = '<i class="fa-solid fa-circle text-yellow-500"></i>';
                    stats.statusText = 'Atención: Sobrecompra';
                    stats.statusColorClass = 'bg-yellow-50 text-yellow-700 border-yellow-200';
                    stats.semaforoVal = 'Atención';
                } else if (isDesbalance) {
                    stats.statusIcon = '<i class="fa-solid fa-circle text-blue-500"></i>';
                    stats.statusText = 'Transferir: Mover ' + amountToTransfer + ' uds';
                    stats.statusColorClass = 'bg-blue-50 text-blue-700 border-blue-200';
                    stats.semaforoVal = 'Transferir';
                } else {
                    stats.statusIcon = '<i class="fa-solid fa-circle text-green-500"></i>';
                    stats.statusText = 'Óptimo';
                    stats.statusColorClass = 'bg-green-50 text-green-700 border-green-200';
                    stats.semaforoVal = 'Óptimo';
                }
            }
        }

