        function processCSVData(rawRows) {
            try {
                let headerIndex = -1;
                
                for (let i = 0; i < Math.min(15, rawRows.length); i++) {
                    if (!rawRows[i]) continue;
                    const rowStr = rawRows[i].join('').toUpperCase();
                    if (rowStr.includes('CATEG') || rowStr.includes('CODIGO') || rowStr.includes('DESCRIPCION') || rowStr.includes('PRODUCTO')) {
                        headerIndex = i; 
                        break;
                    }
                }

                if (headerIndex === -1) headerIndex = 0; 
                
                if (!rawRows[headerIndex]) {
                    throw new Error("El archivo parece estar vacío o no es legible.");
                }

                appData.headers = rawRows[headerIndex].map(h => h ? String(h).trim() : '');
                
                const minCols = Math.max(2, Math.floor(appData.headers.length * 0.3));
                
                appData.rows = rawRows.slice(headerIndex + 1).filter(row => {
                    return row && row.length >= minCols && row.some(cell => cell && String(cell).trim() !== '');
                });

                if (appData.rows.length === 0) {
                    throw new Error("Se detectaron los encabezados, pero no se encontraron filas de datos válidas.");
                }

                appData.isLoaded = true;
                
                analyzeStock();
                
                document.getElementById('stat-rows').innerText = appData.rows.length.toLocaleString();
                document.getElementById('stat-cols').innerText = appData.headers.length;
                document.getElementById('fileStatus').innerHTML = `<i class="fa-solid fa-circle text-green-500 text-[10px] mr-1"></i> <span class="text-gray-700">Documento Activo</span>`;
                document.getElementById('emptyState').classList.add('hidden');

                renderTable();
                renderCharts();
                hideLoader();
                switchTab('dashboard');

            } catch (error) {
                hideLoader();
                console.error("Error detallado:", error);
                alert("Error procesando los datos: " + error.message + "\n\nPor favor, verifica la integridad del archivo.");
            }
        }

