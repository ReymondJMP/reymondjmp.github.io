<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXUS | Plataforma de Análisis de Datos</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Chart.js para las gráficas -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- PapaParse para procesar CSV -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

    <!-- SheetJS (XLSX) para procesar archivos de Excel -->
    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
    
    <!-- Marked para renderizar Markdown del asistente AI -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <!-- jsPDF para generación de reportes en PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    
    <!-- Font Awesome para íconos -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        nexus: {
                            bg: '#f4f7f9',
                            panel: '#ffffff',
                            primary: '#0032a0',
                            secondary: '#0056d6',
                            accent: '#001e60',
                            text: '#1e293b',
                            muted: '#64748b'
                        }
                    }
                }
            }
        }
    </script>
    
    <style>
        body {
            background-color: #f4f7f9;
            color: #1e293b;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 50, 160, 0.1);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }

        /* Custom Scrollbar - Tema Claro */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        .tab-active {
            border-bottom: 2px solid #0032a0;
            color: #0032a0 !important;
        }

        .prose pre {
            background-color: #f8fafc;
            padding: 1rem;
            border-radius: 0.5rem;
            overflow-x: auto;
            border: 1px solid #e2e8f0;
        }
        .prose code { color: #0032a0; }
        .markdown-body p { margin-bottom: 0.75rem; }
        .markdown-body ul { list-style-type: disc; margin-left: 1.5rem; margin-bottom: 0.75rem; }
        .markdown-body strong { color: #0032a0; font-weight: 700; }
        
        /* Local Scrollbar para las listas del dashboard */
        .local-scroll::-webkit-scrollbar { width: 4px; }

        /* Animaciones para Modal */
        .modal-enter { opacity: 1 !important; pointer-events: auto !important; }
        .modal-content-enter { transform: scale(1) !important; }
        
        /* Efectos Hover Interactivos */
        .kpi-card { transition: all 0.3s ease; cursor: pointer; position: relative; overflow: hidden; }
        .kpi-card:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0, 50, 160, 0.1), 0 4px 6px -2px rgba(0, 50, 160, 0.05); border-color: #0032a0; }
        .kpi-card::after { content: 'Click para detalles'; position: absolute; bottom: -20px; left: 0; width: 100%; text-align: center; background: #0032a0; color: white; font-size: 10px; font-weight: bold; padding: 2px 0; transition: bottom 0.3s ease; opacity: 0; }
        .kpi-card:hover::after { bottom: 0; opacity: 1; }
        
        /* Animación del Chat Widget */
        .chat-widget-enter { opacity: 1 !important; transform: scale(1) translateY(0) !important; pointer-events: auto !important; }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden text-nexus-text relative">

    <!-- Header -->
    <header class="glass-panel border-b border-gray-200 p-4 flex justify-between items-center z-10 shrink-0">
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 flex items-center justify-center">
                    <img src="image_b906d0.png" alt="Logo de NEXUS" class="w-full h-full object-contain drop-shadow-sm" onerror="this.src='https://placehold.co/100x100/0032a0/white?text=NX'">
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-wider text-nexus-primary">NEXUS</h1>
                    <p class="text-xs text-nexus-muted uppercase tracking-widest font-medium">Plataforma Analítica</p>
                </div>
            </div>
            
            <!-- Reloj y Referencia del Día Actual -->
            <div class="hidden md:flex items-center gap-2 pl-6 border-l border-gray-300">
                <div class="p-2 bg-blue-50 rounded-lg text-nexus-primary">
                    <i class="fa-regular fa-calendar-clock text-lg"></i>
                </div>
                <div class="flex flex-col">
                    <span class="text-[10px] text-gray-500 font-bold uppercase tracking-wider">Día Actual (Referencia)</span>
                    <span id="currentDateTimeDisplay" class="text-sm font-bold text-nexus-primary">Cargando fecha...</span>
                </div>
            </div>
        </div>
        
        <div class="flex items-center gap-4">
            <label for="csvUpload" class="cursor-pointer bg-white hover:bg-blue-50 border border-gray-300 text-nexus-primary px-4 py-2 rounded-md text-sm font-semibold transition-colors flex items-center gap-2 shadow-sm">
                <i class="fa-solid fa-file-upload"></i> Cargar Datos (CSV/XLSX)
            </label>
            <input type="file" id="csvUpload" accept=".csv, .xlsx, .xls" class="hidden">
            <div id="fileStatus" class="text-sm text-nexus-muted hidden md:flex items-center font-medium">
                <i class="fa-solid fa-circle text-red-500 text-[10px] mr-1"></i> Sin datos
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 flex overflow-hidden">
        
        <!-- Sidebar / Navigation -->
        <aside class="w-20 md:w-64 glass-panel border-r border-gray-200 flex flex-col shrink-0 transition-all bg-white z-20">
            <nav class="flex-1 p-2 md:p-4 space-y-2 mt-4">
                <button onclick="switchTab('dashboard')" id="btn-dashboard" class="w-full flex items-center justify-center md:justify-start gap-3 p-3 rounded-lg text-nexus-muted hover:text-nexus-primary hover:bg-blue-50 transition-colors tab-active">
                    <i class="fa-solid fa-chart-pie text-lg w-6"></i>
                    <span class="hidden md:block font-medium">Dashboard</span>
                </button>
                <button onclick="switchTab('data')" id="btn-data" class="w-full flex items-center justify-center md:justify-start gap-3 p-3 rounded-lg text-nexus-muted hover:text-nexus-primary hover:bg-blue-50 transition-colors">
                    <i class="fa-solid fa-table text-lg w-6"></i>
                    <span class="hidden md:block font-medium">Vista de Datos</span>
                </button>
            </nav>
            <div class="p-4 border-t border-gray-200 hidden md:block bg-gray-50/50">
                <div class="text-xs text-nexus-muted mb-2 font-semibold uppercase tracking-wider">Estadísticas Rápidas</div>
                <div class="flex justify-between items-center text-sm mb-1">
                    <span class="text-gray-600">Total Filas:</span>
                    <span id="stat-rows" class="font-bold text-nexus-primary">0</span>
                </div>
                <div class="flex justify-between items-center text-sm">
                    <span class="text-gray-600">Columnas:</span>
                    <span id="stat-cols" class="font-bold text-nexus-text">0</span>
                </div>
            </div>
        </aside>

        <!-- Content Area -->
        <section class="flex-1 relative overflow-hidden bg-nexus-bg">
            
            <!-- Empty State -->
            <div id="emptyState" class="absolute inset-0 flex flex-col items-center justify-center z-20 bg-nexus-bg p-8 text-center">
                <div class="w-24 h-24 mb-6 rounded-full bg-white flex items-center justify-center border border-gray-200 shadow-md">
                    <i class="fa-solid fa-file-excel text-4xl text-nexus-primary"></i>
                </div>
                <h2 class="text-2xl font-bold text-nexus-primary mb-2">Bienvenido a NEXUS</h2>
                <p class="text-nexus-muted max-w-md mb-8">Para comenzar el análisis, carga el documento FIFO (en formato CSV o XLSX) utilizando el botón superior.</p>
                <button onclick="loadSampleData()" class="px-6 py-2 bg-white border border-nexus-primary text-nexus-primary font-medium rounded-md hover:bg-blue-50 transition-colors shadow-sm">
                    <i class="fa-solid fa-vial mr-2"></i> O carga datos de prueba
                </button>
            </div>

            <!-- Loader -->
            <div id="loader" class="absolute inset-0 z-30 bg-white/80 backdrop-blur-sm hidden flex-col items-center justify-center">
                <i class="fa-solid fa-circle-notch fa-spin text-4xl text-nexus-primary mb-4"></i>
                <p class="text-nexus-primary font-bold animate-pulse mt-4" id="loaderText">Procesando datos...</p>
            </div>

            <!-- TAB 1: Dashboard -->
            <div id="tab-dashboard" class="absolute inset-0 overflow-y-auto p-6 hidden pb-24">
                <h2 class="text-2xl font-bold mb-6 text-nexus-primary border-b border-gray-300 pb-2">Panel de Control General</h2>
                
                <!-- KPIs Interactivos (4 Columnas) -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
                    
                    <!-- KPI 1: Mayor Stock -->
                    <div class="glass-panel bg-white rounded-xl p-4 flex items-center gap-4 shadow-sm border-l-4 border-l-nexus-primary kpi-card" onclick="openModal('topStock')">
                        <div class="p-3 bg-blue-50 rounded-lg text-nexus-primary flex-shrink-0">
                            <i class="fa-solid fa-boxes-stacked text-xl"></i>
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-[10px] text-nexus-muted uppercase tracking-wider mb-0.5 font-bold">Mayor Stock (Uds)</p>
                            <h4 class="text-sm font-bold text-gray-900 truncate" id="kpi-top-stock">Cargando...</h4>
                            <p class="text-[10px] font-bold text-nexus-primary mt-0.5 bg-blue-50 inline-block px-1.5 rounded" id="kpi-top-stock-sub">--</p>
                        </div>
                    </div>
                    
                    <!-- KPI 2: Próxima a Vencer -->
                    <div class="glass-panel bg-white rounded-xl p-4 flex items-center gap-4 shadow-sm border-l-4 border-l-orange-500 kpi-card" onclick="openModal('expiring')">
                        <div class="p-3 bg-orange-50 rounded-lg text-orange-600 flex-shrink-0">
                            <i class="fa-solid fa-clock-rotate-left text-xl"></i>
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-[10px] text-nexus-muted uppercase tracking-wider mb-0.5 font-bold">Cat. Próxima a Vencer</p>
                            <h4 class="text-sm font-bold text-gray-900 truncate" id="kpi-exp-cat">Cargando...</h4>
                            <p class="text-[10px] font-bold text-orange-600 mt-0.5 bg-orange-50 inline-block px-1.5 rounded" id="kpi-exp-cat-sub">--</p>
                        </div>
                    </div>

                    <!-- KPI 3: Oportunidades de Transferencia -->
                    <div class="glass-panel bg-white rounded-xl p-4 flex items-center gap-4 shadow-sm border-l-4 border-l-blue-400 kpi-card" onclick="openModal('transfers')">
                        <div class="p-3 bg-blue-50 rounded-lg text-blue-500 flex-shrink-0">
                            <i class="fa-solid fa-truck-transfer text-xl"></i>
                        </div>
                        <div class="overflow-hidden">
                            <p class="text-[10px] text-nexus-muted uppercase tracking-wider mb-0.5 font-bold">Desbalance Tiendas</p>
                            <h4 class="text-sm font-bold text-gray-900 truncate" id="kpi-transfer">Cargando...</h4>
                            <p class="text-[10px] font-bold text-blue-600 mt-0.5 bg-blue-50 inline-block px-1.5 rounded" id="kpi-transfer-sub">--</p>
                        </div>
                    </div>

                    <!-- KPI 4: Preferencias de Compra -->
                    <div class="glass-panel bg-white rounded-xl p-4 flex items-center gap-4 shadow-sm border-l-4 border-l-purple-500 kpi-card" onclick="openModal('demand')">
                        <div class="p-3 bg-purple-50 rounded-lg text-purple-600 flex-shrink-0">
                            <i class="fa-solid fa-cart-shopping text-xl"></i>
                        </div>
                        <div class="overflow-hidden flex-1">
                            <p class="text-[10px] text-nexus-muted uppercase tracking-wider mb-0.5 font-bold" id="kpi-demand-title">Demanda Mensual</p>
                            <div class="truncate mt-1 flex items-center justify-between">
                                <span class="text-[10px] text-green-600 font-bold bg-green-50 px-1.5 py-0.5 rounded mr-1"><i class="fa-solid fa-arrow-up"></i> Alta</span>
                                <span class="text-[10px] font-bold text-gray-900 truncate flex-1 text-right" id="kpi-top-cat">--</span>
                            </div>
                            <div class="truncate flex items-center justify-between mt-0.5">
                                <span class="text-[10px] text-red-500 font-bold bg-red-50 px-1.5 py-0.5 rounded mr-1"><i class="fa-solid fa-arrow-down"></i> Baja</span>
                                <span class="text-[10px] font-bold text-gray-500 truncate flex-1 text-right" id="kpi-low-cat">--</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    
                    <!-- Preferencias Globales de Compra (Gráfica) -->
                    <div class="glass-panel bg-white rounded-xl p-5 flex flex-col shadow-sm lg:col-span-1 border border-gray-200">
                        <h3 class="text-lg font-bold text-nexus-primary mb-2 flex items-center gap-2 border-b border-gray-200 pb-3">
                            <i class="fa-solid fa-chart-pie"></i> Preferencias de Compra
                        </h3>
                        <p class="text-xs text-gray-500 mb-4 text-center">Distribución basada en salidas mensuales globales por Categoría</p>
                        <div class="flex-1 relative min-h-[250px] cursor-pointer" onclick="openModal('demand')" title="Click para ver reporte completo">
                            <canvas id="chartCategory"></canvas>
                        </div>
                    </div>
                    
                    <!-- Panel de Alertas y Problemáticas -->
                    <div class="glass-panel bg-white rounded-xl p-5 flex flex-col shadow-sm lg:col-span-2">
                        <h3 class="text-lg font-bold text-red-600 mb-4 flex items-center gap-2 border-b border-gray-200 pb-3">
                            <i class="fa-solid fa-triangle-exclamation"></i> Problemáticas de Stock y Gestión Logística
                        </h3>
                        
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 flex-1">
                            <!-- Causa 1: Sobrecompra -->
                            <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 flex flex-col h-[280px] hover:shadow-md transition-shadow cursor-pointer" onclick="switchTab('data')" title="Ver datos filtrados">
                                <h4 class="font-bold text-yellow-600 mb-1">1. Posible Sobrecompra</h4>
                                <p class="text-[10px] text-gray-500 mb-4 border-b border-gray-200 pb-3">Productos con más de 3 lotes o entradas diferentes en existencia simultánea.</p>
                                <ul id="list-overstock" class="text-sm space-y-3 text-gray-700 overflow-y-auto local-scroll pr-2 flex-1">
                                    <li class="flex items-center text-gray-500"><i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Analizando...</li>
                                </ul>
                            </div>
                            
                            <!-- Causa 2: Baja prescripción -->
                            <div class="bg-red-50/30 rounded-lg p-4 border border-red-100 flex flex-col h-[280px] hover:shadow-md transition-shadow cursor-pointer" onclick="openModal('expiring')" title="Ver tabla de fechas">
                                <h4 class="font-bold text-red-600 mb-1">2. Riesgo Prescripción</h4>
                                <p class="text-[10px] text-gray-500 mb-4 border-b border-red-100 pb-3">Stock actual excede la proyección total de salidas antes de su vencimiento.</p>
                                <ul id="list-low-presc" class="text-sm space-y-3 text-gray-700 overflow-y-auto local-scroll pr-2 flex-1">
                                    <li class="flex items-center text-gray-500"><i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Analizando...</li>
                                </ul>
                            </div>

                            <!-- Causa 3: Desbalance de Tiendas -->
                            <div class="bg-blue-50/50 rounded-lg p-4 border border-blue-100 flex flex-col h-[280px] hover:shadow-md transition-shadow cursor-pointer" onclick="openModal('transfers')" title="Ver detalles de transferencia">
                                <h4 class="font-bold text-blue-600 mb-1">3. Desbalance (Transferencias)</h4>
                                <p class="text-[10px] text-gray-500 mb-4 border-b border-blue-100 pb-3">Productos con stock en una sucursal y completamente agotados en la otra.</p>
                                <ul id="list-transfers" class="text-sm space-y-3 text-gray-700 overflow-y-auto local-scroll pr-2 flex-1">
                                    <li class="flex items-center text-gray-500"><i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Analizando...</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Acciones Recomendadas -->
                <div class="glass-panel bg-white rounded-xl p-5 shadow-sm border border-yellow-200 mt-6">
                    <h3 class="text-lg font-bold text-yellow-600 mb-4 flex items-center gap-2 border-b border-yellow-100 pb-3">
                        <i class="fa-solid fa-lightbulb"></i> Plan de Acciones Recomendadas
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="action-plan-container">
                        <div class="flex items-center text-gray-500 text-sm"><i class="fa-solid fa-circle-notch fa-spin mr-2"></i> Generando plan de acción...</div>
                    </div>
                </div>
                
                <!-- Sección de Envío por Correo -->
                <div class="glass-panel bg-white rounded-xl p-5 shadow-sm border border-blue-200 mt-6 bg-gradient-to-r from-blue-50/50 to-white">
                    <h3 class="text-lg font-bold text-nexus-primary mb-4 flex items-center gap-2 border-b border-blue-100 pb-3">
                        <i class="fa-solid fa-envelope-open-text"></i> Control Inteligente por Correo
                    </h3>
                    <p class="text-sm text-gray-600 mb-4">Ingresa tu dirección de correo electrónico para recibir un informe detallado en formato PDF con las alertas de vencimiento, baja rotación y transferencias sugeridas.</p>
                    
                    <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-2/3 lg:w-1/2">
                        <div class="relative w-full">
                            <i class="fa-solid fa-at absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="email" id="reportEmail" placeholder="tu@correo.com" class="w-full bg-white border border-gray-300 rounded-lg py-2.5 pl-10 pr-4 focus:outline-none focus:border-nexus-primary focus:ring-1 focus:ring-nexus-primary text-gray-800 shadow-sm text-sm">
                        </div>
                        <button onclick="sendPDFReport()" class="w-full sm:w-auto px-6 py-2.5 bg-nexus-primary hover:bg-nexus-secondary text-white rounded-lg font-medium transition-colors shadow-md flex items-center justify-center gap-2 text-sm whitespace-nowrap">
                            <i class="fa-solid fa-paper-plane"></i> Enviar PDF
                        </button>
                    </div>
                    <div id="emailFeedback" class="hidden mt-3 text-sm font-medium p-3 rounded-md bg-white border border-gray-100 inline-block"></div>
                </div>

            </div>

            <!-- TAB 2: Data Table -->
            <div id="tab-data" class="absolute inset-0 flex flex-col hidden p-6 overflow-hidden pb-20">
                <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4 shrink-0">
                    <h2 class="text-2xl font-bold text-nexus-primary">Explorador de Registros</h2>
                    
                    <div class="flex flex-col md:flex-row items-center gap-3 w-full md:w-auto">
                        <!-- Filtro de Semáforo -->
                        <div class="relative w-full md:w-auto">
                            <select id="statusFilter" class="w-full md:w-auto bg-white border border-gray-300 rounded-md py-2 pl-3 pr-8 text-sm focus:outline-none focus:border-nexus-primary focus:ring-1 focus:ring-nexus-primary text-gray-800 shadow-sm font-medium" onchange="filterTable()">
                                <option value="ALL">Todos los Estados</option>
                                <option value="Óptimo">🟢 Estado: Óptimo</option>
                                <option value="Atención">🟡 Estado: Atención (Sobrecompra)</option>
                                <option value="Riesgo">🟠 Estado: Riesgo (Baja Prescripción)</option>
                                <option value="Crítico">🔴 Estado: Crítico</option>
                                <option value="Transferir">🔵 Estado: Transferir</option>
                            </select>
                        </div>
                        
                        <!-- Buscador General -->
                        <div class="relative w-full md:w-auto">
                            <i class="fa-solid fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                            <input type="text" id="searchInput" placeholder="Buscar por código, nombre..." class="w-full md:w-64 bg-white border border-gray-300 rounded-md py-2 pl-10 pr-4 text-sm focus:outline-none focus:border-nexus-primary focus:ring-1 focus:ring-nexus-primary text-gray-800 shadow-sm" onkeyup="filterTable()">
                        </div>
                    </div>
                </div>
                <div class="flex-1 overflow-auto rounded-lg border border-gray-200 bg-white shadow-sm relative">
                    <table class="w-full text-left text-sm whitespace-nowrap" id="dataTable">
                        <thead class="bg-gray-100 sticky top-0 z-20 text-nexus-primary font-bold border-b border-gray-300 shadow-sm">
                            <tr id="tableHeadRow">
                                <!-- Headers injected via JS -->
                            </tr>
                        </thead>
                        <tbody id="tableBody" class="divide-y divide-gray-200">
                            <!-- Data injected via JS -->
                        </tbody>
                    </table>
                </div>
                <div class="mt-2 flex justify-between items-center shrink-0">
                    <span id="filteredCount" class="text-xs text-nexus-primary font-bold bg-blue-50 px-2 py-1 rounded"></span>
                    <span class="text-xs text-gray-500 font-medium">Mostrando primeros 500 registros. Usa los filtros para refinar la búsqueda.</span>
                </div>
            </div>
            
        </section>
    </main>

    <!-- FAB (Botón Flotante para Chat) -->
    <button id="fab-ai" onclick="toggleChat()" class="fixed bottom-6 right-6 w-14 h-14 bg-nexus-primary rounded-full shadow-2xl flex items-center justify-center text-white hover:bg-nexus-secondary transition-transform hover:scale-110 z-[60] border-2 border-white">
        <i class="fa-solid fa-robot text-2xl"></i>
        <!-- Notification dot -->
        <span class="absolute top-0 right-0 flex h-3 w-3">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500 border border-white"></span>
        </span>
    </button>

    <!-- Chat Widget Flotante -->
    <div id="chatWidget" class="fixed bottom-24 right-6 w-[90vw] md:w-[400px] h-[550px] bg-white rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.3)] flex-col hidden z-[60] border border-gray-200 overflow-hidden transition-all opacity-0 scale-95 origin-bottom-right pointer-events-none" style="background-image: url('data:image/svg+xml;base64,');">
        
        <!-- Chat Header -->
